{
  "name": "remotion-scaffold",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preview:dev": "vite",
    "remotion:studio": "bunx remotion studio",
    "remotion:bundle": "bunx remotion bundle",
    "remotion:compositions": "bunx remotion compositions",
    "remotion:render": "node scripts/remotion-render.mjs",
    "remotion:render:demo": "REMOTION_OUTPUT=out/scaffold-demo-defaults.mov REMOTION_PROPS_FILE=shared/project/render-presets/default.json npm run remotion:render",
    "deploy:edgeone:url": "EDGEONE_OPEN=0 node scripts/open-edgeone-pages.mjs",
    "deploy:edgeone:open": "node scripts/open-edgeone-pages.mjs",
    "deploy:edgeone": "npm run remotion:bundle && npm run deploy:edgeone:open",
    "dev": "node scripts/dev-workbench.mjs",
    "build": "npm run deploy:edgeone",
    "lint": "eslint .",
    "verify": "npm run lint && npm run remotion:compositions"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@remotion/cli": "4.0.440",
    "@remotion/tailwind-v4": "4.0.440",
    "@tailwindcss/vite": "^4.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.440",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.1"
  }
}
