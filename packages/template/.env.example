# EdgeOne Pages upload URL can be provided directly.
# If set, EDGEONE_PAGES_PROJECT_ID / EDGEONE_PAGES_FROM are ignored.
# EDGEONE_PAGES_UPLOAD_URL=https://console.cloud.tencent.com/edgeone/pages/upload/pages-xxxx?from=deployments

# Or configure by project id:
# EDGEONE_PAGES_PROJECT_ID=pages-nyysufr8rhgo
# EDGEONE_PAGES_FROM=deployments
# EDGEONE_BROWSER_APP=Google Chrome

# Set 0 to print URL only, do not open browser.
# EDGEONE_OPEN=1

# Remotion render runtime options.
# REMOTION_ENTRY_POINT=./remotion/index.jsx
# REMOTION_COMPOSITION_ID=ScaffoldDemo30fps
# REMOTION_FPS=30
# REMOTION_OUTPUT=out/scaffold-demo-alpha.mov
# REMOTION_CODEC=prores
# REMOTION_PRORES_PROFILE=4444
# REMOTION_PIXEL_FORMAT=yuva444p10le
# REMOTION_IMAGE_FORMAT=png
# REMOTION_SCALE=2
# REMOTION_PROPS_JSON={"title":"My Scene"}
# REMOTION_PROPS_FILE=shared/project/render-presets/default.json
# REMOTION_BROWSER_EXECUTABLE=~/Library/Caches/com.zjucat.create-vive-motion/remotion/chrome-headless-shell/remotion-<version>/mac-arm64/chrome-headless-shell-mac-arm64/chrome-headless-shell
